-.Xr bit_fls 3 ,
-.Xr fls 3 ,
-.Xr flsl 3 ,
-.Xr flsll 3 ,
-.Xr stdbit 3 ,
-.Xr stdc_count_leading_zeros 3 ,
-.Xr stdc_first_leading_one 3
