+/* { dg-do compile } */
+/* { dg-additional-options "-O -fdump-tree-backprop-details -std=gnu99" } */
+
+void use (unsigned);
+
+void
+foo (unsigned x)
+{
+  unsigned a = x & 0xff;
+  use (a & 0xf);
+  use (a);
+}
+
+void
+bar (unsigned x, unsigned y)
+{
+  unsigned a = x & 0xff;
+  unsigned b = a + y;
+  use (b & 0xf);
+}
+
+void
+baz (unsigned x, unsigned s)
+{
+  unsigned a = x & 0xff;
+  unsigned b = a << s;
+  use (b & 0xf);
+}
+
+unsigned
+baf (unsigned x, int n)
+{
+  unsigned a = x & 0xff;
+  for (int i = 0; i < n; i++)
+    a = (a + 1) & 0xff;
+  return a;
+}
+
+/* { dg-final { scan-tree-dump-not "Eliding redundant mask" "backprop" } } */
