@@ -0,0 +1,15 @@
+/* { dg-do compile { target rv64 } } */
+/* { dg-additional-options "-march=rv64gc_zicond -mabi=lp64d" } */
+/* { dg-skip-if "" { *-*-* } { "-O0" "-Og"} } */
+
+typedef signed char int8_t;
+int8_t f(int8_t x)
+{
+    int8_t sh = 1 << x;
+    return sh & 1;
+}
