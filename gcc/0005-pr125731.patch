+/* { dg-do compile } */
+/* { dg-options "-march=rv64gcb_zicond -mabi=lp64d" { target rv64 } } */
+/* { dg-options "-march=rv32gcb_zicond -mabi=ilp32" { target rv32 } } */
+/* { dg-skip-if "" { *-*-* } { "-O0" "-Og"} } */
+
+long fun_not1 (int a, long b)
+{
+    if (!(a & 1))
+        b ^= 8;
+    return b;
+}
