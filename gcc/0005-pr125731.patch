+      && rtx_equal_p (XEXP (a, 0), b)
+      && CONST_INT_P (XEXP (a, 1)))
+    {
+      common = XEXP (a, 0);
+      a = XEXP (a, 1);
+      b = CONST0_RTX (GET_MODE (common));
+    }
+
+  if (GET_CODE (b) == PLUS
+      && GET_CODE (a) == REG
+      && rtx_equal_p (XEXP (b, 0), a)
+      && CONST_INT_P (XEXP (b, 1)))
+    {
+      common = XEXP (b, 0);
+      b = XEXP (b, 1);
+      a = CONST0_RTX (GET_MODE (common));
+    }
