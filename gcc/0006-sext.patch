@@ -0,0 +1,24 @@
+/* PR tree-optimization/125405 */
+/* { dg-do compile } */
+/* { dg-options "-O2 -fdump-tree-optimized" } */
+
+typedef unsigned long xlen_t;
+
+xlen_t
+sext8_hd (xlen_t x)
+{
+  return (x & 0x7fUL) - (x & 0x80UL);
+}
+
+xlen_t
+sext16_hd (xlen_t x)
+{
+  return (x & 0x7fffUL) - (x & 0x8000UL);
+}
