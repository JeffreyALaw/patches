diff --git a/gcc/config/riscv/bitmanip.md b/gcc/config/riscv/bitmanip.md
index 27ab3c957821..b2bcde034c96 100644
--- a/gcc/config/riscv/bitmanip.md
+++ b/gcc/config/riscv/bitmanip.md
@@ -1484,3 +1484,20 @@ (define_split
   [(set (match_dup 4) (and:X (not:X (match_dup 2)) (match_dup 1)))
    (set (match_dup 0) (xor:X (match_dup 4) (match_dup 3)))])
 
+;; This would typically be a 3 instruction sequence.  Two shifts plus
+;; the rotate.  But in this form we can push the extension to wrap the
+;; rotate so long as the mask constant preserves bits 31..63.  If the
+;; mask is a small operand, then we win.
+(define_split
+  [(set (match_operand:DI 0 "register_operand")
+        (sign_extend:DI (and:SI (rotatert:SI (match_operand:SI 1 "register_operand")
+                                             (match_operand 2 "const_int_operand"))
+                                (match_operand 3 "const_int_operand"))))
+   (clobber (match_operand:DI 4 "register_operand"))]
+  "(TARGET_64BIT && (TARGET_ZBB || TARGET_ZBKB)
+    && INTVAL (operands[2]) < 32
+    && (INTVAL (operands[3]) & HOST_WIDE_INT_C (0xffffffff80000000)) == HOST_WIDE_INT_C (0xffffffff80000000)
+    && SMALL_OPERAND (INTVAL (operands[3])))"
+  [(set (match_dup 4) (sign_extend:DI (rotatert:SI (match_dup 1) (match_dup 2))))
+   (set (match_dup 0) (and:DI (match_dup 4) (match_dup 3)))])
+
