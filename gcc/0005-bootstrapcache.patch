 		sed -e 's,\./,,g' -e 's,[^/]*/,../,g' `$(srcdir) ;; \
 	esac; \
 	module_srcdir=fixincludes; \
+	cfgcache=; \
+	if test x"${build_alias}" = x"${host_alias}" && test x"${host_alias}" = x"${target_alias}"; then \
+	  cfgcache=$$r/stage-config-cache/fixincludes.cache; \
+	  mkdir -p $$r/stage-config-cache; \
+	  if test -f $$cfgcache; then \
+	    sed -e '/^ac_cv_env_/d' $$cfgcache > $$cfgcache.tmp$$$$ \
+	      && mv -f $$cfgcache.tmp$$$$ $$cfgcache; \
+	  fi; \
+	fi; \
 	$(SHELL) $$s/$$module_srcdir/configure \
 	  --srcdir=$${topdir}/$$module_srcdir \
 	  $(HOST_CONFIGARGS) --build=${build_alias} --host=${host_alias} \
 	  --target=${target_alias} \
 	   \
-	  $(STAGE1_CONFIGURE_FLAGS)
+	  $(STAGE1_CONFIGURE_FLAGS) \
+	  $${cfgcache:+--cache-file=$$cfgcache}
 @endif fixincludes-bootstrap
 
