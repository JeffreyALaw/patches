+host_modules= { module= libdecnumber; bootstrap_cache=true; bootstrap=true;
 		missing=TAGS; };
 host_modules= { module= libgui; };
-host_modules= { module= libiberty; bootstrap=true;
+host_modules= { module= libiberty; bootstrap_cache=true; bootstrap=true;
 	        extra_configure_flags='@extra_host_libiberty_configure_flags@';};
 // Linker plugins may need their own build of libiberty; see
 // gcc/doc/install.texi.  We take care that this build of libiberty doesn't get
@@ -157,7 +157,7 @@ host_modules= { module= utils; no_check=true; };
