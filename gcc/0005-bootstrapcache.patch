+host_modules= { module= libbacktrace; bootstrap_cache=true; bootstrap=true; };
+host_modules= { module= libcpp; bootstrap_cache=true; bootstrap=true; };
 // As with libiconv, don't install any of libcody
-host_modules= { module= libcody; bootstrap=true;
+host_modules= { module= libcody; bootstrap_cache=true; bootstrap=true;
 		no_install= true;
 		missing= pdf;
 		missing= html;
@@ -109,10 +109,10 @@ host_modules= { module= libcody; bootstrap=true;
 		missing= install-info;
 		missing= install-dvi;
 		missing=TAGS; };
