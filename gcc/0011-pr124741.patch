diff --git a/gcc/testsuite/gcc.target/riscv/pr124741.c b/gcc/testsuite/gcc.target/riscv/pr124741.c
new file mode 100644
index 000000000000..a0cd23fced65
--- /dev/null
+++ b/gcc/testsuite/gcc.target/riscv/pr124741.c
@@ -0,0 +1,22 @@
+/* { dg-do compile } */
+/* { dg-options "-march=rv64gcb -mabi=lp64" { target rv64 } } */
+/* { dg-options "-march=rv32gcb -mabi=ilp32" { target rv32 } } */
+/* { dg-skip-if "" { *-*-* } { "-O0" } } */
+
+#define TEST(TYPE, NAME) typedef struct { int x; TYPE repr; } atomic_u_t_##NAME; \
+TYPE atomic_load_##NAME (const atomic_u_t_##NAME *a) { TYPE result; __atomic_load (&a->repr, &result, 0); return result; }
+
+TEST (unsigned char, uc)
+TEST (unsigned short, us)
+TEST (unsigned int, ui)
+TEST (unsigned long, ul)
+
+TEST (signed char, sc)
+TEST (signed short, ss)
+TEST (signed int, si)
+TEST (signed long, sl)
+
+/* { dg-final { scan-assembler-not "sext" } } */
+/* { dg-final { scan-assembler-not "zext" } } */
+/* { dg-final { scan-assembler-not "andi" } } */
+
