
In PR 124741, we have a testcase:

typedef struct
{
  int x;
  unsigned repr;
} atomic_u_t;

unsigned
atomic_load_u (const atomic_u_t *a)
{
  unsigned result;
  __atomic_load (&a->repr, &result, 0);
  return result;
}

When compiled with rv64, it outputs:

addi    a5,a0,4
lw      a0,0(a5)
sext.w  a0,a0
ret

Here we have a redundant sign extension and inefficient address arithmetic.
This can be simplified into two instructions, a load and a return.

The lw insn is already doing a sign extension from 32 to 64 bits, making
the separate sext.w unnecessary. Adding a copy of the pattern that
explicitly shows the sign extension in the RTL, with the modes adjusted
accordingly, no longer emits the sext.w. I also generalized the pattern to
support both sign and zero extension. As Zalarsc doesn't support zero
extending load-acquire instructions, I introduced a new iterator, ensuring
zero extend is limited to !TARGET_ZALRSC.

The addi and lw are combined into lw a0,4(a5) by adjusting the memory
operand constraint to handle offsets in the load pattern. I did the same
for the store pattern where the inefficient address arithmetic problem was
also present. In our new pattern, the validity of the memory operand
constraint depends on the value of operand 2 - the memory model. I
introduced two new constraint alternatives, such that the behavior of the
memory operand constraint is triggered on whether the memory model acquire
is being used or not and the Zalarsc or non-Zalarsc targets accordingly.

All these changes have been reflected on the total store ordering memory
consistency model as well.

PR target/124741

gcc/
    * config/riscv/constraints.md: Added two constraints to trigger
        memory operand constraint behavior.
    * config/riscv/iterators.md: Added an iterator to support the
        conditional zero extend.
    * config/riscv/sync-rvwmo.md: Adjusted constraints; new pattern
        to explicitly show extension.
    * config/riscv/sync-ztso.md: Ditto.

gcc/testsuite/
    * gcc.target/riscv/load.c: Testcases for atomic load compiled with
        rv64.
    * gcc.target/riscv/load32.c: Testcases for atomic load compiled with
        rv32.
    * gcc.target/riscv/store.c: Testcases for atomic store compiled
        with rv64.
    * gcc.target/riscv/store32.c: Testcases for atomic store compiled
        with rv32.
diff --git a/gcc/config/riscv/constraints.md b/gcc/config/riscv/constraints.md
index 1f285a342ba..8e828f06faa 100644
--- a/gcc/config/riscv/constraints.md
+++ b/gcc/config/riscv/constraints.md
@@ -145,6 +145,18 @@
   (and (match_code "mem")
        (match_test "GET_CODE(XEXP(op,0)) == REG")))
 
+(define_constraint "B1"
+  "Memory models that can match with A."
+  (and (match_code "const_int")
+       (and (match_test "ival == MEMMODEL_ACQUIRE")
+            (match_test "TARGET_ZALRSC"))))
+
+(define_constraint "B2"
+  "Memory models that can match with m."
+  (and (match_code "const_int")
+       (ior (match_test "ival != MEMMODEL_ACQUIRE")
+	    (match_test "!TARGET_ZALRSC"))))
+
 (define_constraint "S"
   "A constraint that matches an absolute symbolic address."
   (match_operand 0 "absolute_symbolic_operand"))
diff --git a/gcc/config/riscv/iterators.md b/gcc/config/riscv/iterators.md
index 076911e5e7f..dfb1be0c700 100644
--- a/gcc/config/riscv/iterators.md
+++ b/gcc/config/riscv/iterators.md
@@ -207,6 +207,9 @@
 ;; This code iterator allows signed and unsigned widening multiplications
 ;; to use the same template.
 (define_code_iterator any_extend [sign_extend zero_extend])
+
+(define_code_iterator cond_extend [sign_extend (zero_extend "!TARGET_ZALRSC")])
+
 (define_code_attr extend_name [
   (sign_extend "extend") (zero_extend "zero_extend")
 ])
diff --git a/gcc/config/riscv/sync-rvwmo.md b/gcc/config/riscv/sync-rvwmo.md
index 3d409388837..5025cfeb74d 100644
--- a/gcc/config/riscv/sync-rvwmo.md
+++ b/gcc/config/riscv/sync-rvwmo.md
@@ -49,7 +49,7 @@
 (define_insn "atomic_load_rvwmo<mode>"
   [(set (match_operand:ANYI 0 "register_operand" "=r")
 	(unspec_volatile:ANYI
-	    [(match_operand:ANYI 1 "memory_operand" "A")
+	    [(match_operand:ANYI 1 "memory_operand" "m")
 	     (match_operand:SI 2 "const_int_operand")]  ;; model
 	 UNSPECV_ATOMIC_LOAD))]
   "!TARGET_ZTSO"
@@ -74,10 +74,38 @@
 		      : is_mm_acquire (memmodel_from_int (INTVAL (operands[2]))) ? 8
 		      : 4)"))])
 
+(define_insn "atomic_load_rvwmo<X:mode><SUBX:mode><code>"
+  [(set (match_operand:X 0 "register_operand" "=r,r")
+	(cond_extend:X
+	    (unspec_volatile:SUBX
+		[(match_operand:SUBX 1 "memory_operand" "m,A")
+		(match_operand:SUBX 2 "const_int_operand" "B2,B1")]
+	    UNSPEC_ATOMIC_LOAD)))]
+  "!TARGET_ZTSO"
+  {
+    enum memmodel model = (enum memmodel) INTVAL (operands[2]);
+    model = memmodel_base (model);
+
+    if (model == MEMMODEL_SEQ_CST)
+      return "fence\trw,rw\;"
+             "<SUBX:load><u>\t%0,%1\;"
+             "fence\tr,rw";
+    if (model == MEMMODEL_ACQUIRE)
+      return "<SUBX:load><u>\t%0,%1\;"
+             "fence\tr,rw";
+    else
+      return "<SUBX:load><u>\t%0,%1";
+  }
+  [(set_attr "type" "multi")
+   (set (attr "length")
+        (symbol_ref "(is_mm_seq_cst (memmodel_from_int (INTVAL (operands[2]))) ? 12
+                      : is_mm_acquire (memmodel_from_int (INTVAL (operands[2]))) ? 8
+                      : 4)"))])
+
 ;; Implement atomic stores with conservative fences.
 ;; This allows us to be compatible with the ISA manual Table A.6 and Table A.7.
 (define_insn "atomic_store_rvwmo<mode>"
-  [(set (match_operand:ANYI 0 "memory_operand" "=A")
+  [(set (match_operand:ANYI 0 "memory_operand" "=m")
 	(unspec_volatile:ANYI
 	    [(match_operand:ANYI 1 "reg_or_0_operand" "rJ")
 	     (match_operand:SI 2 "const_int_operand")]  ;; model
diff --git a/gcc/config/riscv/sync-ztso.md b/gcc/config/riscv/sync-ztso.md
index 9bdd9e291d9..1c86029236a 100644
--- a/gcc/config/riscv/sync-ztso.md
+++ b/gcc/config/riscv/sync-ztso.md
@@ -43,7 +43,7 @@
 (define_insn "atomic_load_ztso<mode>"
   [(set (match_operand:ANYI 0 "register_operand" "=r")
 	(unspec_volatile:ANYI
-	    [(match_operand:ANYI 1 "memory_operand" "A")
+	    [(match_operand:ANYI 1 "memory_operand" "m")
 	     (match_operand:SI 2 "const_int_operand")]  ;; model
 	 UNSPECV_ATOMIC_LOAD))]
   "TARGET_ZTSO"
@@ -64,9 +64,32 @@
 	(symbol_ref "(is_mm_seq_cst (memmodel_from_int (INTVAL (operands[2]))) ? 8
 		      : 4)"))])
 
+(define_insn "atomic_load_ztso<X:mode><SUBX:mode><code>"
+  [(set (match_operand:X 0 "register_operand" "=r")
+	(any_extend:X
+	    (unspec_volatile:SUBX
+		[(match_operand:SUBX 1 "memory_operand" "m")
+		(match_operand:SUBX 2 "const_int_operand")]
+	    UNSPEC_ATOMIC_LOAD)))]
+  "TARGET_ZTSO"
+  {
+    enum memmodel model = (enum memmodel) INTVAL (operands[2]);
+    model = memmodel_base (model);
+
+    if (model == MEMMODEL_SEQ_CST)
+      return "fence\trw,rw\;"
+             "<SUBX:load><u>\t%0,%1";
+    else
+      return "<SUBX:load><u>\t%0,%1";
+  }
+  [(set_attr "type" "multi")
+   (set (attr "length")
+        (symbol_ref "(is_mm_seq_cst (memmodel_from_int (INTVAL (operands[2]))) ? 8
+                      : 4)"))])
+
 
 (define_insn "atomic_store_ztso<mode>"
-  [(set (match_operand:ANYI 0 "memory_operand" "=A")
+  [(set (match_operand:ANYI 0 "memory_operand" "=m")
 	(unspec_volatile:ANYI
 	    [(match_operand:ANYI 1 "reg_or_0_operand" "rJ")
 	     (match_operand:SI 2 "const_int_operand")]  ;; model
diff --git a/gcc/testsuite/gcc.target/riscv/load.c b/gcc/testsuite/gcc.target/riscv/load.c
new file mode 100644
index 00000000000..166d9a04cce
--- /dev/null
+++ b/gcc/testsuite/gcc.target/riscv/load.c
@@ -0,0 +1,202 @@
+/* { dg-do compile { target rv64 } } */
+/* { dg-options "-O2 -march=rv64gc -mabi=lp64d" } */
+/* { dg-final { check-function-bodies "**" "" } } */
+
+
+typedef struct
+{
+  char pad;
+  unsigned char repr;
+} qi_zero_t;
+
+typedef struct
+{
+  char pad;
+  signed char repr;
+} qi_sign_t;
+
+typedef struct
+{
+  short pad;
+  unsigned short repr;
+} hi_zero_t;
+
+typedef struct
+{
+  short pad;
+  short repr;
+} hi_sign_t;
+
+typedef struct
+{
+  int pad;
+  int repr;
+} si_sign_t;
+
+typedef struct
+{
+  int pad;
+  unsigned repr;
+} si_zero_t;
+
+
+
+/*
+**atomic_load_qi_zero:
+**	lb	a0,1(a0)
+**	andi	a0,a0,0xff
+**	ret
+*/
+unsigned atomic_load_qi_zero (const qi_zero_t *a) {
+  unsigned char r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_qi_sign:
+**	lb	a0,1(a0)
+**	ret
+*/
+int atomic_load_qi_sign (const qi_sign_t *a) {
+  signed char r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_hi_zero:
+**	lh	a0,2(a0)
+**	slli	a0,a0,48
+**	srli	a0,a0,48
+**	ret
+*/
+unsigned atomic_load_hi_zero (const hi_zero_t *a) {
+  unsigned short r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_hi_sign:
+**	lh	a0,2(a0)
+**	ret
+*/
+int atomic_load_hi_sign (const hi_sign_t *a) {
+  short r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_si_sign:
+**	lw	a0,4(a0)
+**	ret
+*/
+int atomic_load_si_sign (const si_sign_t *a) {
+  int r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_si_zero:
+**	lw	a0,4(a0)
+**	ret
+*/
+unsigned atomic_load_si_zero (const si_zero_t *a) {
+  unsigned r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+
+typedef struct
+{
+  int pad;
+  unsigned long long repr;
+} di_t;
+
+typedef struct
+{
+  int pad;
+  unsigned char repr;
+} qi_di_t;
+
+
+/*
+**atomic_load_di:
+**	ld	a0,8(a0)
+**	ret
+*/
+unsigned long long atomic_load_di (const di_t *a) {
+  unsigned long long r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_qi_di:
+**	lb	a0,4(a0)
+**	andi	a0,a0,0xff
+**	ret
+*/
+unsigned long long atomic_load_qi_di (const qi_di_t *a) {
+  unsigned char r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+typedef struct
+{
+  int pad;
+  unsigned repr;
+} t;
+
+
+/*
+**atomic_load_relaxed:
+**	lw	a0,4(a0)
+**	ret
+*/
+unsigned atomic_load_relaxed (const t *a) {
+  unsigned r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_acquire:
+**	lw	a0,4(a0)
+**	fence	r,rw
+**	sext.w	a0,a0
+**	ret
+*/
+unsigned atomic_load_acquire (const t *a) {
+  unsigned r;
+  __atomic_load (&a->repr, &r, __ATOMIC_ACQUIRE);
+  return r;
+}
+
+
+/*
+**atomic_load_seqcs:
+**	fence	rw,rw
+**	lw	a0,4(a0)
+**	fence	r,rw
+**	ret
+*/
+unsigned atomic_load_seqcst (const t *a) {
+  unsigned r;
+  __atomic_load (&a->repr, &r, __ATOMIC_SEQ_CST);
+  return r;
+}
diff --git a/gcc/testsuite/gcc.target/riscv/load32.c b/gcc/testsuite/gcc.target/riscv/load32.c
new file mode 100644
index 00000000000..236ad88dde4
--- /dev/null
+++ b/gcc/testsuite/gcc.target/riscv/load32.c
@@ -0,0 +1,160 @@
+/* { dg-do compile { target rv32 } } */
+/* { dg-options "-O2 -march=rv32gc -mabi=ilp32" } */
+/* { dg-final { check-function-bodies "**" "" } } */
+
+typedef struct
+{
+  char pad;
+  unsigned char repr;
+} qi_zero_t;
+
+typedef struct
+{
+  char pad;
+  signed char repr;
+} qi_sign_t;
+
+typedef struct
+{
+  short pad;
+  unsigned short repr;
+} hi_zero_t;
+
+typedef struct
+{
+  short pad;
+  short repr;
+} hi_sign_t;
+
+typedef struct
+{
+  int pad;
+  int repr;
+} si_sign_t;
+
+typedef struct
+{
+  int pad;
+  unsigned repr;
+} si_zero_t;
+
+
+/*
+**atomic_load_qi_zero:
+**	lb	a0,1(a0)
+**	andi	a0,a0,0xff
+**	ret
+*/
+unsigned atomic_load_qi_zero (const qi_zero_t *a) {
+  unsigned char r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_qi_sign:
+**	lb	a0,1(a0)
+**	ret
+*/
+int atomic_load_qi_sign (const qi_sign_t *a) {
+  signed char r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_hi_zero:
+**	lh	a0,2(a0)
+**	slli	a0,a0,16
+**	srli	a0,a0,16
+**	ret
+*/
+unsigned atomic_load_hi_zero (const hi_zero_t *a) {
+  unsigned short r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_hi_sign:
+**	lh	a0,2(a0)
+**	ret
+*/
+int atomic_load_hi_sign (const hi_sign_t *a) {
+  short r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_si_sign:
+**	lw	a0,4(a0)
+**	ret
+*/
+int atomic_load_si_sign (const si_sign_t *a) {
+  int r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_si_zero:
+**	lw	a0,4(a0)
+**	ret
+*/
+unsigned atomic_load_si_zero (const si_zero_t *a) {
+  unsigned r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+typedef struct
+{
+  int pad;
+  unsigned repr;
+} t;
+
+
+/*
+**atomic_load_relaxed:
+**	lw	a0,4(a0)
+**	ret
+*/
+unsigned atomic_load_relaxed (const t *a) {
+  unsigned r;
+  __atomic_load (&a->repr, &r, __ATOMIC_RELAXED);
+  return r;
+}
+
+
+/*
+**atomic_load_acquire:
+**	lw	a0,4(a0)
+**	fence	r,rw
+**	ret
+*/
+unsigned atomic_load_acquire (const t *a) {
+  unsigned r;
+  __atomic_load (&a->repr, &r, __ATOMIC_ACQUIRE);
+  return r;
+}
+
+
+/*
+**atomic_load_seqcst:
+**	fence	rw,rw
+**	lw	a0,4(a0)
+**	fence	r,rw
+**	ret
+*/
+unsigned atomic_load_seqcst (const t *a) {
+  unsigned r;
+  __atomic_load (&a->repr, &r, __ATOMIC_SEQ_CST);
+  return r;
+}
diff --git a/gcc/testsuite/gcc.target/riscv/store.c b/gcc/testsuite/gcc.target/riscv/store.c
new file mode 100644
index 00000000000..437cd2f65c1
--- /dev/null
+++ b/gcc/testsuite/gcc.target/riscv/store.c
@@ -0,0 +1,122 @@
+/* { dg-do compile { target rv64 } } */
+/* { dg-options "-O2 -march=rv64gc -mabi=lp64d" } */
+/* { dg-final { check-function-bodies "**" "" } } */
+
+typedef struct
+{
+  char pad;
+  unsigned char repr;
+} qi_s_t;
+
+typedef struct
+{
+  short pad;
+  unsigned short repr;
+} hi_s_t;
+
+typedef struct
+{
+  int pad;
+  unsigned repr;
+} si_s_t;
+
+
+/*
+**atomic_store_qi:
+**	sb	a1,1(a0)
+**	ret
+*/
+void
+atomic_store_qi (qi_s_t *a, unsigned char val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+/*
+**atomic_store_hi:
+**	sh	a1,2(a0)
+**	ret
+*/
+void
+atomic_store_hi (hi_s_t *a, unsigned short val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+/*
+**atomic_store_si:
+**	sw	a1,4(a0)
+**	ret
+*/
+void
+atomic_store_si (si_s_t *a, unsigned val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+typedef struct
+{
+  int pad;
+  unsigned long long repr;
+} di_s_t;
+
+
+/*
+**atomic_store_di:
+**	sd	a1,8(a0)
+**	ret
+*/
+void
+atomic_store_di (di_s_t *a, unsigned long long val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+typedef struct
+{
+  int pad;
+  unsigned repr;
+} s_mm;
+
+
+/*
+**atomic_store_relaxed:
+**	sw	a1,4(a0)
+**	ret
+*/
+void
+atomic_store_relaxed (s_mm *a, unsigned val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+/*
+**atomic_store_release:
+**	fence	rw,w
+**	sw	a1,4(a0)
+**	ret
+*/
+void
+atomic_store_release (s_mm *a, unsigned val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELEASE);
+}
+
+
+/*
+**atomic_store_seqcst:
+**	fence	rw,w
+**	sw	a1,4(a0)
+**	fence	rw,rw
+**	ret
+*/
+void
+atomic_store_seqcst (s_mm *a, unsigned val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_SEQ_CST);
+}
diff --git a/gcc/testsuite/gcc.target/riscv/store32.c b/gcc/testsuite/gcc.target/riscv/store32.c
new file mode 100644
index 00000000000..38e5d8ecfe9
--- /dev/null
+++ b/gcc/testsuite/gcc.target/riscv/store32.c
@@ -0,0 +1,105 @@
+/* { dg-do compile { target rv32 } } */
+/* { dg-options "-O2 -march=rv32gc -mabi=ilp32" } */
+/* { dg-final { check-function-bodies "**" "" } } */
+
+typedef struct
+{
+  char pad;
+  unsigned char repr;
+} qi_s_t;
+
+typedef struct
+{
+  short pad;
+  unsigned short repr;
+} hi_s_t;
+
+typedef struct
+{
+  int pad;
+  unsigned repr;
+} si_s_t;
+
+
+/*
+**atomic_store_qi:
+**	sb	a1,1(a0)
+**	ret
+*/
+void
+atomic_store_qi (qi_s_t *a, unsigned char val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+/*
+**atomic_store_hi:
+**	sh	a1,2(a0)
+**	ret
+*/
+void
+atomic_store_hi (hi_s_t *a, unsigned short val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+/*
+**atomic_store_si:
+**	sw	a1,4(a0)
+**	ret
+*/
+void
+atomic_store_si (si_s_t *a, unsigned val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+
+
+typedef struct
+{
+  int pad;
+  unsigned repr;
+} s_mm;
+
+
+/*
+**atomic_store_relaxed:
+**	sw	a1,4(a0)
+**	ret
+*/
+void
+atomic_store_relaxed (s_mm *a, unsigned val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELAXED);
+}
+
+
+/*
+**atomic_store_release:
+**	fence	rw,w
+**	sw	a1,4(a0)
+**	ret
+*/
+void
+atomic_store_release (s_mm *a, unsigned val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_RELEASE);
+}
+
+
+/*
+**atomic_store_seqcst:
+**	fence	rw,w
+**	sw	a1,4(a0)
+**	fence	rw,rw
+**	ret
+*/
+void
+atomic_store_seqcst (s_mm *a, unsigned val)
+{
+  __atomic_store (&a->repr, &val, __ATOMIC_SEQ_CST);
+}

