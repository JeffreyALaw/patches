 gcc/testsuite/gcc.dg/tree-ssa/pr64567-2.c | 52 +++++++++++++++++++++++
 gcc/testsuite/gcc.dg/tree-ssa/pr64567.c   | 40 +++++++++++++++++
 3 files changed, 112 insertions(+)
