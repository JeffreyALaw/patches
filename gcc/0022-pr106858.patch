+/* Some targets have operations that sign extend their result to a
+   wider mode.  For example the "w" forms for RISC-V in 64 bit mode.
+
+   When the upper bits are not live, then we would like to replace
+   the extension with a widening SUBREG which carries that semantic
+   information.  That in turn can allow combine to do a better job
+   in certain cases.
+
+   The code here are meant to stay in sync with the set combine
+   uses for deciding to split at a sign extension rather than
+   the inner operation. 
+
+   Return true of CODE is one of those opcodes, false otherwise.  */
+static bool
+op_may_be_extended (rtx_code code)
+{
+  return (code == PLUS || code == MINUS
+	  || code == MULT || code == DIV
+	  || code == MOD || code == ASHIFT
+	  || code == LSHIFTRT || code == ASHIFTRT
+	  || code == ROTATE || code == ROTATERT
+	  || code == NEG);
+}
+
 
